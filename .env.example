# ========================================
# Environment Variables
# ========================================
# Copy this file to .env and add your actual API keys
# NEVER commit .env to version control!

# OpenAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic/Claude API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Pinecone (for Level 2 if using cloud vector DB)
# PINECONE_API_KEY=...
# PINECONE_ENVIRONMENT=...

# Optional: LangSmith for monitoring (Level 5)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...
# LANGCHAIN_PROJECT=genai-learning

# Optional: Hugging Face (for Level 4 - fine-tuning)
# HUGGINGFACE_API_KEY=...

# Healthcare Data Settings (IMPORTANT!)
# NEVER use real PHI in development
USE_SYNTHETIC_DATA=true
ENABLE_PHI_DETECTION=true
